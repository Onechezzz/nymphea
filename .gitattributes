# Force LF line endings in the repository for all text files
* text=auto eol=lf

# Explicitly declare text files
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.toml text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.env  text eol=lf

# Binary files — no conversion
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.webp binary
*.mp4  binary
*.mov  binary
*.webm binary
*.ico  binary
*.woff binary
*.woff2 binary
